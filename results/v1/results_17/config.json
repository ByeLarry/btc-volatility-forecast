    "dropout": 0.4,
    "activation": "relu"
  },
  "lstm": {
    "units": [20],
    "dropout": 0.3,
    "recurrent_dropout": 0.0,
    "dense_units": [4],
    "activation": "relu"
  },
  "saving": {
    "save_models": false,
    "save_predictions": true,
    "save_metrics": true,
    "save_plots": true
